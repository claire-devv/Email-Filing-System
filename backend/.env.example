APP_ENV=local
DATABASE_URL=sqlite:///./runtime/rres_phase1.db
ARTIFACT_ROOT=./runtime/artifacts
FOLDER_RULEBOOK_PATH=./data/folder_structure.json

AUTO_FILE_CONFIDENCE=80
URGENT_REVIEW_CONFIDENCE=50
MAX_FILE_SIZE_MB=500
ZIP_MAX_DEPTH=3
ZIP_MAX_EXTRACTED_MB=500
CLAUDE_PDF_MAX_MB=32
CLAUDE_PDF_MAX_PAGES=100

CLASSIFIER_MODE=mock
ENABLE_REAL_CLAUDE=false
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_DAILY_CALL_LIMIT=20
CLAUDE_MAX_CALLS_PER_PROCESS=1
CLAUDE_MAX_PROMPT_CHARS=24000

ENABLE_REAL_GOOGLE=false
PROCESS_UNREAD_MAX_LIMIT=5
GOOGLE_CLIENT_SECRET_FILE=./credentials/client_secret.json
GOOGLE_TOKEN_FILE=./credentials/token.json
GOOGLE_OAUTH_STATE_FILE=./runtime/google_oauth_states.json
GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:8088/auth/google/callback
GOOGLE_OAUTH_SUCCESS_REDIRECT_URL=
GOOGLE_OAUTH_ERROR_REDIRECT_URL=
GOOGLE_APPLICATION_CREDENTIALS=
GMAIL_USER_ID=me
GMAIL_PUBSUB_TOPIC_NAME=
GMAIL_PUBSUB_LABEL_IDS=["INBOX"]
GMAIL_PUBSUB_LABEL_FILTER_BEHAVIOR=INCLUDE
GMAIL_FILED_LABEL=RRES-Filed
GMAIL_FAILED_LABEL=RRES-Failed
GMAIL_SKIPPED_LABEL=RRES-Skipped

# Relay inboxes that forward mail for every client; learning never records their
# sender/domain (JSON list).
FORWARDER_DOMAINS=["rockreservices.com"]

DRIVE_ROOT_ID=
DRIVE_ROOT_NAME=RRES - Books
NEEDS_REVIEW_FOLDER_NAME=Needs Review
UPLOAD_COMBINED_PACKAGE=true
ADMIN_API_KEY=

# Dashboard login (bearer-token auth for the React dashboard). All three required to
# enable /auth/login and protect the dashboard API routes. Generate the secret with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
DASHBOARD_AUTH_EMAIL=admin@example.com
DASHBOARD_AUTH_PASSWORD=change-me
AUTH_JWT_SECRET=
AUTH_TOKEN_TTL_MINUTES=720
